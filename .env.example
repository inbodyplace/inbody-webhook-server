# Server port (default: 3000)
PORT=3000

# InBody Developers API
# Base URL for the InBody API server
INBODY_API_BASE_URL=https://kr.developers.lookinbody.com

# Your LBWeb account ID (from InBody Developers login)
INBODY_ACCOUNT=your_lbweb_account

# Your API key (generated in InBody Developers > API Setup)
INBODY_API_KEY=your_api_key_here

# Optional: Validate incoming webhooks using a custom header
# Configure the same header in InBody Developers > API Setup > Webhook Settings > Custom Headers
WEBHOOK_HEADER_NAME=X-InBody-Secret
WEBHOOK_HEADER_VALUE=your_secret_value
